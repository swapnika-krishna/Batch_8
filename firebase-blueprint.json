{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user basic information and app preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User full name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" },
        "isResumeUploaded": { "type": "boolean", "description": "Whether the user has uploaded their resume" }
      },
      "required": ["uid", "email", "displayName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user document containing profile data."
    }
  }
}
